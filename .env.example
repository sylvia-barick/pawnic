# PAWnic Environment Variables
# Copy this file to .env.local and fill in the values from your Supabase project.

# Supabase API Settings
# Found in: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-sb-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-sb-service-role-key
